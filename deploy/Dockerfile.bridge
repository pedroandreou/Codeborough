# Codeborough UI bridge (ui/bridge.mjs) + openclaw CLI (it spawns `openclaw agent`).
# The bridge runs the agent EMBEDDED (in-process) with the full brain config and reaches vLLM
# directly on core_net - this avoids depending on the gateway daemon's WS, which is unreliable
# across the version split. bridge.mjs imports ../plugins/civic-geo/src/geo.mjs.
FROM node:22-bookworm-slim
ENV NODE_ENV=production
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# openclaw 2026.6.1 (match the gateway). /ask spawns `openclaw agent`, which runs embedded.
RUN npm install -g openclaw@2026.6.1 || npm install -g openclaw

WORKDIR /app
COPY ui/ /app/ui/
COPY plugins/civic-geo/ /app/plugins/civic-geo/
# The embedded agent needs the SAME setup as the gateway: brain/provider/model config, the
# civic-geo tool plugin, and the agent skill.
COPY deploy/openclaw.gateway.json /root/.openclaw/openclaw.json
COPY deploy/skills/ /root/.openclaw/skills/
COPY plugins/civic-geo/ /opt/civic-geo/
RUN cd /opt/civic-geo && (openclaw plugins install ./ --force || echo "plugin install warn")

EXPOSE 8091
CMD ["node","/app/ui/bridge.mjs"]
