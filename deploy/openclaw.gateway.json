{
  "gateway": { "mode": "local" },
  "agents": {
    "defaults": {
      "model": { "primary": "vllm/nemotron-nano" }
    }
  },
  "plugins": {
    "entries": {
      "vllm": { "enabled": true },
      "searxng": { "enabled": false }
    }
  },
  "models": {
    "providers": {
      "vllm": {
        "request": { "allowPrivateNetwork": true },
        "models": [
          {
            "id": "nemotron-nano",
            "name": "NVIDIA Nemotron-3 Nano NVFP4 (local)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 65536,
            "maxTokens": 2048
          }
        ]
      }
    }
  },
  "session": {
    "dmScope": "main",
    "reset": { "idleMinutes": 1440 }
  }
}
