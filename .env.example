# Codeborough - copy to .env and fill in. .env is gitignored (never commit keys).
# ---- voice (the ONLY thing allowed to egress) ----
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_v3

# ---- brain: Nemotron NVFP4 via vLLM ----
BRAIN_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-NVFP4
BRAIN_SERVED_NAME=nemotron-nano
VLLM_MAX_MODEL_LEN=65536   # 32768 is too small: OpenClaw's agent baseline prompt alone is ~30k tokens.
                           # 64k leaves ~34k for the conversation. Raise toward 131072
                           # if the GB10 has room (Nemotron supports it; KV cache grows with this value).
VLLM_GPU_FRAC=0.45      # 0.45 x 121.7GB unified ~= 55GB; leaves headroom on the shared GB10 pool

# ---- gateway auth (openclaw 2026.6.1 requires a token for non-loopback bind) ----
OPENCLAW_GATEWAY_TOKEN=codeborough-local   # shared between gateway + bridge; only on the internal core_net

# ---- ports (host-published only; internal services are NOT published) ----
UI_PORT=8091          # browser hits http://<box>:8091
